# API Keys
FMP_API_KEY=your_fmp_api_key_here
FRED_API_KEY=your_fred_api_key_here

# OpenBB API Keys (automatically detected by OpenBB Platform)
OPENBB_FMP_API_KEY=your_fmp_api_key_here
OPENBB_FRED_API_KEY=your_fred_api_key_here

# Server
PORT=8345

# Database
DATABASE_PATH=./data/stocks.db

# Cache TTL (hours)
CACHE_TTL_HOURS=24

# Python Configuration
PYTHON_PATH=./venv/bin/python
# Windows example:
# PYTHON_PATH=.\venv\Scripts\python.exe

# OpenBB Timeout (milliseconds)
OPENBB_TIMEOUT_MS=30000

# Provider Priority
PRIMARY_FUNDAMENTALS_PROVIDER=fmp
FALLBACK_PROVIDERS=yfinance,intrinio
PRIMARY_QUOTE_PROVIDER=fmp
FALLBACK_QUOTE_PROVIDERS=yfinance,intrinio
PRIMARY_PROFILE_PROVIDER=fmp
FALLBACK_PROFILE_PROVIDERS=yfinance,intrinio

# Note:
# If all OpenBB fundamentals providers fail, the backend will try a direct
# Yahoo Finance fallback automatically before returning an error.
